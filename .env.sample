# =============================================================================
# oscar-2fa-provision configuration
# =============================================================================
# Copy this file to .env and populate with your environment's values.
# The .env file is loaded by python-dotenv when the script starts.
# Do not commit .env to source control.

# -----------------------------------------------------------------------------
# Database connection
# -----------------------------------------------------------------------------
DB_USER=tfa_admin
DB_SECRET=
DB_HOST=                  # FQDN or IP of the OSCAR DB host (or SSH host when tunnelling)
DB_PORT=3306
DB_DATABASE=oscar_15
DB_COMPRESS=true

# -----------------------------------------------------------------------------
# SSH tunnel (optional)
# -----------------------------------------------------------------------------
# Set SSH_ENABLED=true if the DB is only reachable via an SSH tunnel.
# When enabled, the script connects to DB_HOST:SSH_PORT, opens a forward to
# SSH_DB_HOST:DB_PORT, and talks to the DB through the local end of the tunnel.
SSH_ENABLED=false
SSH_DB_HOST=127.0.0.1     # remote-side DB host as seen from the SSH server
SSH_USER=root
SSH_PORT=22
PKEY_FILE=ssh/oscar_db.key
CERT_SECRET=              # passphrase for the SSH key (leave blank if none)

# -----------------------------------------------------------------------------
# SMTP (for sending the provisioning document to the user)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=465
# Connection mode: 'ssl' (port 465) or 'starttls' (port 587) or 'plain' (no TLS, not recommended)
SMTP_MODE=ssl
SMTP_USER=
SMTP_PASSWORD=
FROM_ADDR=                # e.g. it-support@yourclinic.ca
FROM_FRIENDLY=IT Support  # display name shown in the user's inbox

# Optional CC list — comma-separated, no spaces required. Each address
# will be CC'd on every successfully-sent provisioning email, giving
# clinic managers / assistants a copy for their records. Leave blank
# to skip. The CC only fires when the user's email is also being
# sent — it isn't a fallback channel.
# Example:  CC_ADDRS=manager@yourclinic.ca,assistant@yourclinic.ca
CC_ADDRS=

# -----------------------------------------------------------------------------
# 2FA / TOTP parameters baked into the QR
# -----------------------------------------------------------------------------
# These match what 2FA_gen.sh expects when rotating PINs.
TOTP_ISSUER=OSCAR EMR
TOTP_ALGORITHM=sha256
TOTP_DIGITS=6
TOTP_PERIOD=30
# Optional logo URL embedded into the otpauth:// URI; some authenticator apps
# display this next to the entry. Leave blank to omit.
TOTP_IMAGE_URL=

# -----------------------------------------------------------------------------
# OSCAR sign-in details printed in the user's document
# -----------------------------------------------------------------------------
OSCAR_LOGIN_URL=https://your-oscar-host:8443/oscar
INITIAL_PASSWORD=Qwerty123
CLINIC_ADMIN_CONTACT=your clinic administrator

# -----------------------------------------------------------------------------
# Output destinations
# -----------------------------------------------------------------------------
# Local directory where each generated PDF is saved (always written).
OUTPUT_DIR=./output

# Optional Nextcloud (or any other) directory mounted on this host. If set,
# the script also copies the PDF there after generating it. Leave blank to
# skip — the feature can be enabled later without code changes.
NEXTCLOUD_DIR=

# Audit log location.
LOG_DIR=./logs

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
VERBOSE=1
